# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Required for proximity alert emails (list subscribers server-side)
SUPABASE_SERVICE_ROLE_KEY=

# Resend — https://resend.com
RESEND_API_KEY=
RESEND_FROM_EMAIL=DUI Checkpoints Locator <noreply@californiaduicheckpoints.com>

# Report checkpoint notifications (comma-separated)
CHECKPOINT_REPORT_ADMIN_EMAILS=info@webds.com,mohit@webds.com

# Proximity alerts: max distance from user zip to checkpoint (miles)
CHECKPOINT_ALERT_RADIUS_MILES=40

# Optional: Supabase Database Webhook on Checkpoints INSERT → POST /api/webhooks/checkpoint-created
CHECKPOINT_WEBHOOK_SECRET=

# Public site URL for email logo, links, and CTA buttons (production domain)
NEXT_PUBLIC_SITE_URL=https://californiaduicheckpoints.com

# Vercel Cron — upcoming checkpoint reminder emails (every 15 min via vercel.json)
# Vercel sends: Authorization: Bearer <CRON_SECRET>
CRON_SECRET=
